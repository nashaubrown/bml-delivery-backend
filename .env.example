# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. Local example:
#   createdb trippay
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trippay

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_value
JWT_EXPIRES_IN=7d

# ─── App ─────────────────────────────────────────────────────────────────────
# Public origin used to build invite links shown in the UI.
NEXT_PUBLIC_APP_URL=http://localhost:3000
