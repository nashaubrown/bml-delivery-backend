# ─── Database ────────────────────────────────────────────────────────────────
# For Railway/Render this is provided automatically as DATABASE_URL
DATABASE_URL=postgresql://username:password@localhost:5432/bml_delivery

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of your frontend (update after deploying frontend)
FRONTEND_URL=http://localhost:3000
